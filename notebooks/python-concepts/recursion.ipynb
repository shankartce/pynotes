   "source": [
    "def factorial(n):\n",
    "    if n < 0:\n",
    "        raise ValueError(\"n must be a non-negative integer\")\n",
    "    if n in (0, 1):\n",
    "        return 1\n",
    "    return n * factorial(n - 1)\n",
    "\n",
    "for value in range(6):\n",
    "    print(f\"factorial({value}) = {factorial(value)}\")"
   ]
  }
